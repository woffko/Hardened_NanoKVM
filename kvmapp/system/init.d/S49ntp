#!/bin/sh

DAEMON=/usr/sbin/ntpd
PIDFILE=/var/run/ntpd.pid
CONFIG_FILE=/etc/kvm/time.json

NTPD_ARGS=" -g"
[ -r /etc/default/ntpd ] && . /etc/default/ntpd

ntp_enabled() {
    [ -r "$CONFIG_FILE" ] || return 0

    enabled="$(sed -n 's/.*"ntpEnabled"[[:space:]]*:[[:space:]]*\(true\|false\).*/\1/p' "$CONFIG_FILE" 2>/dev/null | head -n 1)"
    [ "$enabled" = "false" ] && return 1
    return 0
}

start() {
    printf 'Starting ntpd: '
    if ! ntp_enabled; then
        echo 'disabled'
        return 0
    fi
    start-stop-daemon -S -q -b -m -p "$PIDFILE" -x "$DAEMON" -- $NTPD_ARGS -p "$PIDFILE"
    [ $? = 0 ] && echo OK || echo FAIL
}

stop() {
    printf 'Stopping ntpd: '
    start-stop-daemon -K -q -p "$PIDFILE" || killall ntpd 2>/dev/null || true
    rm -f "$PIDFILE"
    echo OK
}

restart() {
    stop
    start
}

case "$1" in
    start|stop|restart)
        "$1"
        ;;
    reload)
        restart
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|reload}"
        exit 1
        ;;
esac
