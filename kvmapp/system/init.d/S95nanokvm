#!/bin/sh
# nanokvm Rev3.1

disable_stale_autostarts() {
    for script in /etc/init.d/S95nanokvm.*; do
        [ -e "$script" ] || continue
        mv "$script" "/etc/init.d/disabled-${script##*/}" 2>/dev/null || chmod 0644 "$script" 2>/dev/null
    done
}

WATCHDOG_PID_FILE=/tmp/nanokvm-watchdog.pid
H264_SAFE_MODE_FILE=/etc/kvm/h264_safe_mode
SYSTEM_UPDATE_PUBLIC_KEY=/etc/kvm/system-update-signing.pub.pem
SYSTEM_UPDATE_BUNDLED_PUBLIC_KEY=/kvmapp/system/keys/system-update-signing.pub.pem

wait_process_exit() {
    name="$1"
    for _ in 1 2 3 4 5; do
        pidof "$name" >/dev/null 2>&1 || return 0
        sleep 1
    done
    killall -9 "$name" 2>/dev/null
    sleep 1
}

stop_watchdog() {
    if [ -f "$WATCHDOG_PID_FILE" ]; then
        pid="$(cat "$WATCHDOG_PID_FILE" 2>/dev/null)"
        [ -n "$pid" ] && kill "$pid" 2>/dev/null
        rm -f "$WATCHDOG_PID_FILE"
    fi
}

cleanup_server_backups() {
    rm -rf \
        /kvmapp/server/web.old \
        /kvmapp/server/web.prev \
        /kvmapp/server/web.backup \
        /kvmapp/server/web.backup-* \
        /kvmapp/server/web.before-* \
        /kvmapp/server/web.after-* 2>/dev/null || true
}

ensure_kvm_state_files() {
    mkdir -p /kvmapp/kvm
    [ -f /kvmapp/kvm/now_fps ] || printf '0\n' > /kvmapp/kvm/now_fps
    [ -f /kvmapp/kvm/fps ] || printf '30\n' > /kvmapp/kvm/fps
    [ -f /kvmapp/kvm/qlty ] || printf '2000\n' > /kvmapp/kvm/qlty
    [ -f /kvmapp/kvm/res ] || printf '0\n' > /kvmapp/kvm/res
    # H.264 can wedge the vendor encoder badly enough that the web backend
    # keeps listening on TCP but stops answering HTTP. Always boot into MJPEG;
    # users can still select H.264 explicitly after the UI is reachable.
    printf 'mjpeg\n' > /kvmapp/kvm/type
    [ -f /kvmapp/kvm/gop ] || printf '50\n' > /kvmapp/kvm/gop
    [ -f /kvmapp/kvm/state ] || printf '0\n' > /kvmapp/kvm/state
    [ -f /kvmapp/kvm/width ] || printf '1920\n' > /kvmapp/kvm/width
    [ -f /kvmapp/kvm/height ] || printf '1080\n' > /kvmapp/kvm/height
}

install_system_update_public_key() {
    [ -f "$SYSTEM_UPDATE_BUNDLED_PUBLIC_KEY" ] || return
    mkdir -p /etc/kvm
    if ! cmp -s "$SYSTEM_UPDATE_BUNDLED_PUBLIC_KEY" "$SYSTEM_UPDATE_PUBLIC_KEY"; then
        cp "$SYSTEM_UPDATE_BUNDLED_PUBLIC_KEY" "$SYSTEM_UPDATE_PUBLIC_KEY"
        chmod 0644 "$SYSTEM_UPDATE_PUBLIC_KEY"
    fi
}

start_server_runtime() {
    rm -rf /tmp/server 2>/dev/null
    cp -r /kvmapp/server /tmp/
    nohup /tmp/server/NanoKVM-Server >/tmp/nanokvm-server.log 2>&1 &
}

health_check() {
    if command -v curl >/dev/null 2>&1; then
        curl -fsS --max-time 3 http://127.0.0.1/api/health >/dev/null 2>&1 && return 0
        curl -kfsS --max-time 3 https://127.0.0.1/api/health >/dev/null 2>&1 && return 0
    fi
    if command -v wget >/dev/null 2>&1; then
        wget -q -T 3 -O - http://127.0.0.1/api/health >/dev/null 2>&1 && return 0
    fi
    return 1
}

restart_server_safe() {
    mkdir -p /etc/kvm /kvmapp/kvm
    printf 'mjpeg\n' > /kvmapp/kvm/type
    printf 'H.264 encoder health check failed; restarted in MJPEG safe mode\n' > "$H264_SAFE_MODE_FILE"
    killall NanoKVM-Server 2>/dev/null
    wait_process_exit NanoKVM-Server
    start_server_runtime
}

start_watchdog() {
    [ -f "$WATCHDOG_PID_FILE" ] && kill -0 "$(cat "$WATCHDOG_PID_FILE" 2>/dev/null)" 2>/dev/null && return

    (
        failures=0
        sleep 20
        while true; do
            if ! pidof NanoKVM-Server >/dev/null 2>&1; then
                echo "$(date '+%Y-%m-%d %H:%M:%S') NanoKVM-Server is not running; restarting in MJPEG safe mode" >> /tmp/nanokvm-watchdog.log
                restart_server_safe
                failures=0
                sleep 10
                continue
            fi

            if health_check; then
                failures=0
            else
                failures=$((failures + 1))
                echo "$(date '+%Y-%m-%d %H:%M:%S') NanoKVM-Server health check failed ($failures/3)" >> /tmp/nanokvm-watchdog.log
            fi

            if [ "$failures" -ge 3 ]; then
                echo "$(date '+%Y-%m-%d %H:%M:%S') restarting NanoKVM-Server in MJPEG safe mode" >> /tmp/nanokvm-watchdog.log
                restart_server_safe
                failures=0
                sleep 10
            fi

            sleep 10
        done
    ) &
    echo $! > "$WATCHDOG_PID_FILE"
}

stop_runtime() {
    stop_watchdog
    killall kvm_system 2>/dev/null
    killall NanoKVM-Server 2>/dev/null
    wait_process_exit kvm_system
    wait_process_exit NanoKVM-Server
    rm -rf /tmp/kvm_system /tmp/server 2>/dev/null
}

start_runtime() {
    cleanup_server_backups
    install_system_update_public_key
    ensure_kvm_state_files

    cp -r /kvmapp/kvm_system /tmp/
    nohup /tmp/kvm_system/kvm_system >/tmp/kvm_system.log 2>&1 &

    start_server_runtime
    start_watchdog
}

case "$1" in
  start)
    disable_stale_autostarts
    stop_runtime

    echo -n kvm > /boot/hostname.prefix

    # Copy sensor config if the file exists
    [ -f /mnt/data/sensor_cfg.ini.LT ] && cp /mnt/data/sensor_cfg.ini.LT /mnt/data/sensor_cfg.ini

    # Generate unique device key
    if [ -f /sys/class/cvi-base/base_uid ]; then
        str_value=$(awk '{print $2}' /sys/class/cvi-base/base_uid)
        first_uint=$(echo "$str_value" | cut -d'_' -f1)
        second_uint=$(echo "$str_value" | cut -d'_' -f2)
        echo "$first_uint$second_uint" > /device_key
    fi

    # Set iptables rules (skip if already present)
    iptables -C INPUT -i eth0 -p tcp --dport 80 -m state --state NEW,ESTABLISHED -j ACCEPT 2>/dev/null || \
    iptables -A INPUT -i eth0 -p tcp --dport 80 -m state --state NEW,ESTABLISHED -j ACCEPT

    iptables -C OUTPUT -o eth0 -p tcp --sport 80 -m state --state ESTABLISHED -j ACCEPT 2>/dev/null || \
    iptables -A OUTPUT -o eth0 -p tcp --sport 80 -m state --state ESTABLISHED -j ACCEPT

    iptables -C INPUT -i eth0 -p tcp --dport 443 -m state --state NEW,ESTABLISHED -j ACCEPT 2>/dev/null || \
    iptables -A INPUT -i eth0 -p tcp --dport 443 -m state --state NEW,ESTABLISHED -j ACCEPT

    iptables -C OUTPUT -o eth0 -p tcp --sport 443 -m state --state ESTABLISHED -j ACCEPT 2>/dev/null || \
    iptables -A OUTPUT -o eth0 -p tcp --sport 443 -m state --state ESTABLISHED -j ACCEPT

    iptables -C INPUT -i eth0 -p tcp --sport 22 -m state --state NEW,ESTABLISHED -j ACCEPT 2>/dev/null || \
    iptables -A INPUT -i eth0 -p tcp --sport 22 -m state --state NEW,ESTABLISHED -j ACCEPT

    iptables -C OUTPUT -o eth0 -p tcp --dport 22 -m state --state ESTABLISHED -j ACCEPT 2>/dev/null || \
    iptables -A OUTPUT -o eth0 -p tcp --dport 22 -m state --state ESTABLISHED -j ACCEPT

    iptables -C OUTPUT -o eth0 -p tcp --sport 8000 -m state --state ESTABLISHED -j DROP 2>/dev/null || \
    iptables -A OUTPUT -o eth0 -p tcp --sport 8000 -m state --state ESTABLISHED -j DROP

    # Logo selection
    if [ -f /boot/logo.ico ]; then
        if [ ! -f /kvmapp/server/web/original.ico ]; then
            mv /kvmapp/server/web/sipeed.ico /kvmapp/server/web/original.ico
            cp /boot/logo.ico /kvmapp/server/web/sipeed.ico
        fi
    else
        if [ -f /kvmapp/server/web/original.ico ]; then
            mv /kvmapp/server/web/original.ico /kvmapp/server/web/sipeed.ico
        fi
    fi

    # Start services
    start_runtime
   ;;

  stop)
    stop_runtime
    echo "OK"
   ;;

  restart)
    stop_runtime
    start_runtime
    sync
    echo "OK"
   ;;
    
  *)
    echo "Usage: $0 {start|stop|restart}"
    exit 1
  ;;
esac
